{
    "name": "rahatulrabbi/talkbridge",
    "description": "A professional real-time chat package for Laravel with private and group conversations, message reactions, file attachments, message status tracking, and WebSocket support.",
    "type": "library",
    "keywords": [
        "laravel",
        "chat",
        "real-time",
        "websocket",
        "reverb",
        "pusher",
        "messaging",
        "group-chat",
        "reactions",
        "broadcast"
    ],
    "homepage": "https://github.com/learnwithfair/laravel-chat",
    "license": "MIT",
    "authors": [
        {
            "name": "MD. RAHATUL RABBI",
            "email": "rahatul.ice.09.pust@gmail.com",
            "homepage": "https://github.com/learnwithfair",
            "role": "Software Engineer"
        }
    ],
    "require": {
        "php": "^8.2 || ^8.3 || ^8.4 || ^8.5 || ^8.6 || ^8.7 || ^8.8 || ^8.9 || ^9.0 || ^9.1 || ^9.2 || ^9.3 || ^9.4 || ^10.0 || ^10.1 || ^10.2 || ^10.3 || ^10.4 || ^10.5 || ^10.6 || ^10.7 || ^10.8 || ^10.9 || ^11.0",
        "laravel/framework": "^11.0|^12.0 |^13.0 |^14.0 |^15.0 |^16.0",
        "laravel/sanctum": "^4.0 || ^5.0 || ^6.0 || ^7.0 || ^8.0 || ^9.0"
    },
    "suggest": {
        "laravel/reverb": "Required for real-time WebSocket broadcasting via Reverb.",
        "pusher/pusher-php-server": "Required if using Pusher as broadcast driver.",
        "kreait/laravel-firebase": "Required for FCM push notifications."
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "RahatulRabbi\\LaravelChat\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "RahatulRabbi\\LaravelChat\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "RahatulRabbi\\LaravelChat\\LaravelChatServiceProvider"
            ],
            "aliases": {
                "LaravelChat": "RahatulRabbi\\LaravelChat\\Facades\\Chat"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}